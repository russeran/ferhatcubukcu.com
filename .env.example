# Copy to .env.local and set secrets before production.

# Session signing secret (generate: openssl rand -base64 32). Required on Vercel / production.
AUTH_SECRET=change-me-to-a-long-random-string

# Option A — local or any host with a writable `data/` folder: plain password (hashed into data/auth.json on first login).
ADMIN_PASSWORD=change-this-password

# Option B — Vercel / read-only filesystem: bcrypt hash only (generate: npm run hash-admin-password -- "YourPassword").
# If set, this takes precedence over data/auth.json and ADMIN_PASSWORD.
# ADMIN_PASSWORD_HASH=
