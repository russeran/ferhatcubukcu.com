# Copy to .env.local and set secrets before production.

# Public site URL for sitemaps, canonicals, and Open Graph (use your real domain on Vercel).
# NEXT_PUBLIC_SITE_URL=https://ferhatcubukcu.com

# Session signing secret (generate: openssl rand -base64 32). Required on Vercel / production.
AUTH_SECRET=change-me-to-a-long-random-string

# Admin login password (plain text). Same value in Vercel env — no hash or file required.
ADMIN_PASSWORD=change-this-password

# Optional: bcrypt hash instead of plain ADMIN_PASSWORD (takes precedence if set).
# npm run hash-admin-password -- "YourPassword"
# ADMIN_PASSWORD_HASH=

# --- Vercel / serverless persistence (pick one; Supabase is free tier friendly) ---

# Supabase (free tier): Postgres JSON + Storage for uploads — no paid Redis required.
# Create project at https://supabase.com → SQL Editor run the table SQL from README →
# Storage: create public bucket "portfolio-media" (or set SUPABASE_STORAGE_BUCKET).
# SUPABASE_URL=https://xxxx.supabase.co
# (or use the same value as NEXT_PUBLIC_SUPABASE_URL from Supabase API settings)
# SUPABASE_SERVICE_ROLE_KEY=   # server only — never expose to the browser
# SUPABASE_STORAGE_BUCKET=portfolio-media

# Upstash Redis (also has a generous free tier): Vercel Storage → Redis — optional if you prefer Redis over Supabase.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# (Legacy names KV_REST_API_URL / KV_REST_API_TOKEN also work.)

# Vercel Blob (optional if you use Supabase Storage for images instead).
# BLOB_READ_WRITE_TOKEN=
