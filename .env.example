# Copy to .env.local and set secrets before production.

# --- Search & social (production) ---
# Public canonical URL: REQUIRED for correct sitemap, robots, and Open Graph on your real domain.
# Without this on Vercel, URLs often default to *.vercel.app and Google may not treat ferhatcubukcu.com as the indexed site.
NEXT_PUBLIC_SITE_URL=https://ferhatcubukcu.com
# Local preview: you can use http://localhost:3000 so Open Graph URLs match your dev server.

# Optional: Google Search Console → Settings → Ownership verification → "HTML tag" method (content value only).
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Session signing secret (generate: openssl rand -base64 32). Required on Vercel / production.
AUTH_SECRET=change-me-to-a-long-random-string

# Admin login password (plain text). Same value in Vercel env — no hash or file required.
ADMIN_PASSWORD=change-this-password

# Optional: bcrypt hash instead of plain ADMIN_PASSWORD (takes precedence if set).
# npm run hash-admin-password -- "YourPassword"
# ADMIN_PASSWORD_HASH=

# --- Vercel / serverless persistence (pick one; Supabase is free tier friendly) ---

# Supabase (free tier): auto-creates Storage buckets — no SQL or manual bucket setup.
# SUPABASE_URL=   (or NEXT_PUBLIC_SUPABASE_URL)
# SUPABASE_SERVICE_ROLE_KEY=   # server only
# Optional overrides:
# SUPABASE_KV_BUCKET=portfolio-site-kv
# SUPABASE_STORAGE_BUCKET=portfolio-media

# Upstash Redis (also has a generous free tier): Vercel Storage → Redis — optional if you prefer Redis over Supabase.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# (Legacy names KV_REST_API_URL / KV_REST_API_TOKEN also work.)

# Instagram Graph API (optional — powers /{locale}/instagram grid for a professional account).
# Requires Business or Creator Instagram linked to a Facebook Page. See Meta: Instagram Graph API → IG User → media.
# INSTAGRAM_USER_ID=
# INSTAGRAM_ACCESS_TOKEN=
# Optional override (default v21.0):
# INSTAGRAM_GRAPH_API_VERSION=v21.0
